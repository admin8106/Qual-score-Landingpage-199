# ─── QualScore Frontend — Production Environment ──────────────────────────────
#
# Used when building with: vite build (MODE defaults to "production")
# Committed to source control — contains NO secrets.
# All values that must remain secret (Supabase anon key, Razorpay key) must be
# injected at build time via your CI/CD platform (Netlify / Vercel / etc.)
#
# Minimum required for the app to function:
#   VITE_API_BASE_URL      — your deployed backend origin
#   VITE_SUPABASE_URL      — from Supabase project settings
#   VITE_SUPABASE_ANON_KEY — from Supabase project settings
# ──────────────────────────────────────────────────────────────────────────────

# Backend API — production server
# Replace with your actual deployed backend origin.
VITE_API_BASE_URL=https://api.qualscore.in

# Frontend canonical URL
VITE_APP_URL=https://qualscore.in

# Supabase — inject via CI/CD platform; never commit real keys
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Razorpay publishable key (live mode)
# Safe to include here — it is already public in the SDK payload.
# The Razorpay secret key lives only on the backend.
VITE_RAZORPAY_KEY_ID=

# Analytics — add your real IDs here or via CI/CD
VITE_GA4_MEASUREMENT_ID=
VITE_META_PIXEL_ID=

# Error tracking
VITE_SENTRY_DSN=

# ─── Feature flags ────────────────────────────────────────────────────────────
# Flip to "true" only after backend integration is live and load-tested.

VITE_FF_LINKEDIN_ANALYSIS=false
VITE_FF_LLM_REPORT=false
VITE_FF_CRM_SYNC=false
VITE_FF_NOTIFICATIONS=false

# ─── Operational mode flags ───────────────────────────────────────────────────
# Set to false in production once the Java backend is live and VITE_API_BASE_URL
# is pointing to the real deployed server. Keeping this true in production means
# payments are simulated and no real charges occur — do NOT deploy with true.
VITE_OP_MOCK_PAYMENT=false
