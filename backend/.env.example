# ─────────────────────────────────────────────────────────────────────────────
# QualCore Backend — Environment Variable Reference
#
# Copy this file to .env for local development:
#   cp .env.example .env
#
# NEVER commit .env to version control — it is listed in .gitignore.
#
# Production values are injected through the Render environment dashboard
# (or your deployment platform's secrets manager).
#
# Variables marked [REQUIRED in prod] will produce a WARN log on startup
# if they are missing or use the insecure default when SPRING_PROFILES_ACTIVE=prod.
# ─────────────────────────────────────────────────────────────────────────────


# ═══════════════════════════════════════════════════════════════════════════════
# 1. APPLICATION IDENTITY
# ═══════════════════════════════════════════════════════════════════════════════

# Active Spring profile: local | dev | test | staging | prod
# Controls which application-<profile>.yml overlay is loaded.
SPRING_PROFILES_ACTIVE=dev

# Logical environment tag used in metrics and logs.
APP_ENV=local

# Server port. Render injects PORT automatically — do not hardcode a value in prod.
PORT=8080


# ═══════════════════════════════════════════════════════════════════════════════
# 2. DATABASE
# ═══════════════════════════════════════════════════════════════════════════════

# [REQUIRED in prod]
# DATABASE_URL — the single-connection-string format injected by Render, Railway,
# Heroku, and most PaaS platforms automatically.
#
# Format: jdbc:postgresql://<host>:<port>/<dbname>?sslmode=require
#
# When DATABASE_URL is set it takes priority over DB_URL.
# For local development you can use either DATABASE_URL or the triplet below.
DATABASE_URL=

# Alternate triplet for local development / custom Postgres deployments.
# Ignored when DATABASE_URL is set.
DB_URL=jdbc:postgresql://localhost:5432/qualcore
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Flyway migrations (schema version control).
# Set to false only in testing environments that use in-memory H2.
FLYWAY_ENABLED=true

# HikariCP pool sizing — increase in high-concurrency production environments.
# DB_POOL_SIZE=10
# DB_POOL_MIN_IDLE=2


# ═══════════════════════════════════════════════════════════════════════════════
# 3. FRONTEND URL
# ═══════════════════════════════════════════════════════════════════════════════

# [REQUIRED in prod]
# Public-facing URL of the React frontend application.
# Used to build deep-links in:
#   - Candidate report ready emails / WhatsApp messages   → /report/<code>
#   - Consultation nudge messages                         → /booking/<code>
#   - Booking confirmation notifications                  → /booking/<code>
#
# Example values:
#   Production : https://app.qualscore.in
#   Staging    : https://staging.qualscore.in
#   Local dev  : http://localhost:5173
#
# Startup will log a WARN if this points to localhost while running in prod profile.
FRONTEND_URL=http://localhost:5173


# ═══════════════════════════════════════════════════════════════════════════════
# 4. SECURITY — JWT & ADMIN
# ═══════════════════════════════════════════════════════════════════════════════

# [REQUIRED in prod]
# Secret used to sign and verify admin JWT tokens.
# Must be a randomly generated string, minimum 64 characters.
# Generate: openssl rand -base64 64
# NEVER use the default value in staging or production.
JWT_SECRET=change-this-in-production-use-a-long-random-string

# JWT token lifetime in milliseconds. Default: 24 hours (86400000 ms).
JWT_EXPIRATION_MS=86400000

# BCrypt work factor for password hashing (range: 10–14).
# Higher = slower login but more resistant to brute-force.
# Default 12 is a safe baseline; use 14 for extra security if CPU allows.
BCRYPT_STRENGTH=12

# Admin user seeding — creates the first admin record on startup if none exists.
# Set ADMIN_SEED_ENABLED=false in production after first deployment.
# CHANGE email/password from the defaults before going live.
ADMIN_SEED_ENABLED=true
ADMIN_EMAIL=admin@qualscore.in
ADMIN_PASSWORD=Admin@2024!
ADMIN_FULL_NAME=QualScore Admin

# CORS — comma-separated list of allowed frontend origins.
# In production: set to your actual domain(s), e.g.:
#   CORS_ALLOWED_ORIGINS=https://app.qualscore.in,https://www.qualscore.in
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:4173


# ═══════════════════════════════════════════════════════════════════════════════
# 5. PAYMENT GATEWAY
# ═══════════════════════════════════════════════════════════════════════════════

# Payment provider to activate.
# Values: mock (default, safe for dev/test) | razorpay | payu
#
# mock     → All payment flows return synthetic success/failure — no real charges.
# razorpay → Routes through Razorpay; requires RAZORPAY_* keys below.
# payu     → Routes through PayU; requires PAYU_* keys below.
INTEGRATIONS_PAYMENT_PROVIDER=mock

# ── Razorpay ──────────────────────────────────────────────────────────────────
# Required when INTEGRATIONS_PAYMENT_PROVIDER=razorpay.
#
# RAZORPAY_KEY_ID
#   Public key shown in Razorpay Dashboard → Settings → API Keys.
#   Starts with "rzp_test_" (test) or "rzp_live_" (production).
#
# RAZORPAY_KEY_SECRET
#   Secret key from the same location. Treat as a password — never log or expose.
#
# RAZORPAY_WEBHOOK_SECRET
#   Secret you set in Razorpay Dashboard → Webhooks when registering your endpoint.
#   Used to verify the X-Razorpay-Signature header on incoming webhook events.
#   Webhook URL: https://<your-api-domain>/api/v1/payments/webhook
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── PayU ──────────────────────────────────────────────────────────────────────
# Required when INTEGRATIONS_PAYMENT_PROVIDER=payu.
#
# PAYU_MERCHANT_KEY
#   Merchant key provided in your PayU dashboard.
#
# PAYU_MERCHANT_SALT
#   Merchant salt (secret) used for HMAC signature computation.
#   Treat as a password — never log or expose.
#
# PAYU_BASE_URL
#   Test: https://test.payu.in
#   Live: https://secure.payu.in
PAYU_MERCHANT_KEY=
PAYU_MERCHANT_SALT=
PAYU_BASE_URL=https://test.payu.in


# ═══════════════════════════════════════════════════════════════════════════════
# 6. OPENAI (AI Report Generation)
# ═══════════════════════════════════════════════════════════════════════════════

# When OPENAI_API_KEY is absent or OPENAI_ENABLED=false, report generation
# automatically falls back to the deterministic rule-based engine — no errors.
#
# OPENAI_API_KEY
#   Secret key starting with "sk-" from platform.openai.com → API Keys.
#   Never log the full key — the masked version (first 8 + last 4 chars) is used in logs.
#
# OPENAI_MODEL
#   The model ID passed to the Chat Completions endpoint.
#   Recommended: gpt-4o (best structured JSON output).
#   Alternatives: gpt-4-turbo, gpt-3.5-turbo (faster/cheaper, lower quality).
#
# OPENAI_ENABLED
#   Explicit gate. Even if OPENAI_API_KEY is present, AI is off unless this is true.
#   Set to true in production only after testing your prompt output in staging.
OPENAI_API_KEY=
OPENAI_ENABLED=false
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.2
OPENAI_TIMEOUT_SECONDS=60
OPENAI_MAX_RETRIES=1


# ═══════════════════════════════════════════════════════════════════════════════
# 7. PAYU / RAZORPAY KEYS (summary — see section 5 for details)
# ═══════════════════════════════════════════════════════════════════════════════
# Keys are listed in section 5 above alongside their usage notes.


# ═══════════════════════════════════════════════════════════════════════════════
# 8. EMAIL PROVIDER
# ═══════════════════════════════════════════════════════════════════════════════

# Email provider to use for transactional notifications.
# Values: stub (default, no HTTP calls) | resend
#
# stub   → Logs email content only — safe for local dev and CI.
# resend → Sends via Resend.com API; requires RESEND_API_KEY and a verified domain.
EMAIL_PROVIDER=stub

# RESEND_API_KEY
#   API key from resend.com → API Keys.
#   Starts with "re_".
#   Required when EMAIL_PROVIDER=resend.
RESEND_API_KEY=

# Sender identity — must be a domain you have verified in Resend → Domains.
EMAIL_FROM_ADDRESS=reports@qualscore.in
EMAIL_FROM_NAME=QualScore

# Optional reply-to address. Defaults to EMAIL_FROM_ADDRESS when blank.
EMAIL_REPLY_TO=

# EMAIL_TIMEOUT_SECONDS=15


# ═══════════════════════════════════════════════════════════════════════════════
# 9. WHATSAPP BUSINESS (Meta Cloud API)
# ═══════════════════════════════════════════════════════════════════════════════

# WhatsApp provider.
# Values: stub (default, no HTTP calls) | meta (Meta WhatsApp Business Cloud API)
WHATSAPP_PROVIDER=stub

# WHATSAPP_ACCESS_TOKEN
#   A permanent system-user access token from Meta Business Manager.
#   Path: Business Manager → System Users → Generate Token
#   Required scopes: whatsapp_business_messaging, whatsapp_business_management
#   Required when WHATSAPP_PROVIDER=meta.
WHATSAPP_ACCESS_TOKEN=

# WHATSAPP_PHONE_NUMBER_ID
#   The numeric Phone Number ID from Meta → WhatsApp → API Setup.
#   This is NOT the display phone number; it is the internal API identifier.
WHATSAPP_PHONE_NUMBER_ID=

# WHATSAPP_BUSINESS_ACCOUNT_ID
#   Your Meta Business Account (WABA) ID.
WHATSAPP_BUSINESS_ACCOUNT_ID=

# WHATSAPP_WEBHOOK_VERIFY_TOKEN
#   A secret string YOU define. Set the exact same value in:
#   Meta Business Manager → WhatsApp → Configuration → Webhooks → Verify Token
#   Used to authenticate Meta's webhook challenge (GET requests).
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# WHATSAPP_API_VERSION=v19.0
# WHATSAPP_TIMEOUT_SECONDS=15
# WHATSAPP_MAX_RETRIES=2


# ═══════════════════════════════════════════════════════════════════════════════
# 10. CRM INTEGRATION
# ═══════════════════════════════════════════════════════════════════════════════

# CRM provider.
# Values: stub (default, no HTTP calls) | webhook (generic HTTP POST to any CRM)
CRM_PROVIDER=stub
CRM_ENABLED=true

# CRM_ENDPOINT / CRM_WEBHOOK_URL
#   Full HTTPS URL that receives JSON POST payloads when a candidate event fires.
#
#   Works with any webhook-capable system:
#     Zapier     : https://hooks.zapier.com/hooks/catch/<id>/<token>/
#     Make (Integromat): https://hook.eu1.make.com/<token>
#     n8n        : https://your-n8n.domain.com/webhook/crm-lead
#     HubSpot    : Use HubSpot → Operations Hub → Custom Webhook trigger
#     Salesforce : Use a connected app or Platform Event listener endpoint
#     Internal   : https://your-crm.domain.com/api/leads/ingest
#
#   Required when CRM_PROVIDER=webhook.
CRM_WEBHOOK_URL=

# CRM_WEBHOOK_SECRET
#   Shared secret sent as: Authorization: Bearer <CRM_WEBHOOK_SECRET>
#   Your receiving endpoint should validate this header.
CRM_WEBHOOK_SECRET=

# Override the auth header name/prefix if your endpoint uses a non-standard scheme.
# CRM_WEBHOOK_AUTH_HEADER=Authorization
# CRM_WEBHOOK_AUTH_PREFIX=Bearer

# Legacy / future native CRM SDK keys (unused until a native provider is added).
CRM_API_KEY=
CRM_API_URL=
CRM_OWNER_ID=

# CRM_TIMEOUT_SECONDS=10
# CRM_MAX_RETRIES=2


# ═══════════════════════════════════════════════════════════════════════════════
# ADDITIONAL INTEGRATIONS
# ═══════════════════════════════════════════════════════════════════════════════

# LinkedIn Enrichment (Proxycurl)
# When absent, LinkedIn analysis uses rule-based scoring instead.
PROXYCURL_API_KEY=

# Slack (Internal ops alerts — high-priority lead notifications)
SLACK_WEBHOOK_URL=

# Calendly (Consultation booking)
CALENDLY_API_KEY=
CALENDLY_EVENT_TYPE_URI=

# Integration environment mode: SANDBOX | LIVE
# LIVE activates real payment and communication providers.
ENVIRONMENT_MODE=SANDBOX


# ═══════════════════════════════════════════════════════════════════════════════
# OPERATIONAL
# ═══════════════════════════════════════════════════════════════════════════════

# Rate limiting — enable in staging/prod to protect public endpoints.
RATE_LIMIT_ENABLED=false
RATE_LIMIT_PUBLIC_RPM=60
RATE_LIMIT_ADMIN_RPM=120

# Log level for com.qualscore package.
# local/dev: DEBUG | staging: DEBUG | prod: INFO
LOG_LEVEL=DEBUG
