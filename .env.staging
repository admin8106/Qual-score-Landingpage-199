# ─── QualScore Frontend — Staging Environment ─────────────────────────────────
#
# Used when building with: VITE_MODE=staging vite build --mode staging
# Committed to source control — contains no secrets.
# Secret values (Supabase keys, Razorpay key) must be injected at build time
# via your CI/CD platform's environment variables, not written here.
# ──────────────────────────────────────────────────────────────────────────────

# Backend API — staging server
VITE_API_BASE_URL=https://api-staging.qualscore.in

# Frontend canonical URL
VITE_APP_URL=https://staging.qualscore.in

# Supabase — inject via CI/CD, do not commit real keys here
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Razorpay — use test-mode key for staging
VITE_RAZORPAY_KEY_ID=

# Analytics — omit on staging to avoid polluting production data
VITE_GA4_MEASUREMENT_ID=
VITE_META_PIXEL_ID=

# Error tracking — point to a staging project in Sentry if available
VITE_SENTRY_DSN=

# ─── Feature flags ────────────────────────────────────────────────────────────
# Enable features that are ready for QA on staging.
# Keep disabled until the backend integration is verified.

VITE_FF_LINKEDIN_ANALYSIS=false
VITE_FF_LLM_REPORT=false
VITE_FF_CRM_SYNC=false
VITE_FF_NOTIFICATIONS=false
